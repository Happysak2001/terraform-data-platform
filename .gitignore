# ─────────────────────────────────────────
# SENSITIVE FILES — never commit these
# ─────────────────────────────────────────

# Your real values — contains DB password and key pair name
terraform.tfvars

# SSH private key — never share this
*.pem
*.pem.pub

# AWS credentials
.aws/
credentials

# ─────────────────────────────────────────
# TERRAFORM INTERNALS — not needed in Git
# ─────────────────────────────────────────

# Downloaded plugins (too large, regenerated by terraform init)
.terraform/
.terraform.lock.hcl

# State files — stored in S3, not Git
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Lambda zip — regenerated automatically by Terraform
modules/data_layer/lambda/handler.zip

# Terraform plan output files
*.tfplan
